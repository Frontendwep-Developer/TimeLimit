    <!-- Help (FAQ) Section -->
    <string name="help_faq_title">❓ FAQ</string>
    <string name="faq_q1">How does the limit work?</string>
    <string name="faq_a1">After setting a time limit, the app only works for that duration. When time is up, the app is blocked for 24 hours.</string>
    <string name="faq_q2">What to do when an app is blocked?</string>
    <string name="faq_a2">You can only use the blocked app after 24 hours. The duration cannot be changed.</string>
    <string name="faq_q3">How to change the limit time?</string>
    <string name="faq_a3">Select the app from the list, click \'Edit\', and set a new time.</string>
