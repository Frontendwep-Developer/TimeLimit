<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Yuklanish (Loading) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <!-- Asosiy Ro'yxat -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp"
        android:visibility="gone"
        tools:listitem="@layout/item_app" />

    <!-- Bo'sh holat (Empty State) -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        tools:visibility="gone">

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_blur_circle"
                android:alpha="0.1"/>
            
             <ImageView
                 android:layout_width="120dp"
                 android:layout_height="120dp"
                 android:layout_gravity="center"
                 android:src="@drawable/ic_hourglass_empty"
                 app:tint="@color/primary"/>

             <androidx.cardview.widget.CardView
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_gravity="top|end"
                 android:layout_marginTop="40dp"
                 android:layout_marginEnd="40dp"
                 app:cardCornerRadius="16dp"
                 app:cardElevation="4dp">
                 <ImageView
                     android:layout_width="24dp"
                     android:layout_height="24dp"
                     android:layout_margin="12dp"
                     android:src="@drawable/ic_timer"
                     app:tint="@color/primary"/>
             </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginBottom="60dp"
                android:layout_marginStart="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_margin="12dp"
                    android:src="@drawable/ic_block"
                    app:tint="@color/primary"/>
            </androidx.cardview.widget.CardView>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hech qanday limit qo'shilmagan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/slate_900"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vaqtingizdan unumli foydalanish uchun ilovalarga cheklovlar o'rnating va kuningizni nazorat qiling."
            android:textSize="16sp"
            android:textColor="@color/slate_500"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.2"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_app_large"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        android:text="ILOVA QO'SHISH"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        android:backgroundTint="@color/primary"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:backgroundTint="@color/primary"
        android:text="QO'SHISH"
        android:textColor="@color/white"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/white"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>