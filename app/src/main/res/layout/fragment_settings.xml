                android:layout_marginTop="24dp"
                android:text="Versiya 1.0.0"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/slate_400" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yangilanishlar"
                    android:textColor="@color/settings_primary"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_chip_selected"
                    android:backgroundTint="@color/slate_200"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maxfiylik kelishuvi"
                    android:textColor="@color/settings_primary"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
