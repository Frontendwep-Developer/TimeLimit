<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view_settings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    tools:context=".ui.settings.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- 1. HEADER (O'zgarishsiz) -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="SOZLAMALAR"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/btn_close"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Ilova sozlamalari va boshqaruv paneli"
                        android:textColor="@color/gray_700"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@+id/tv_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

                    <ImageButton
                        android:id="@+id/btn_close"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- 2. CONTENT -->
        <LinearLayout
            android:id="@+id/settings_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- LANGUAGE SECTION HEADER (Toggle) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layout_language_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_language"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="TIL"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_current_language"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="O'zbekcha"
                        android:textColor="@color/gray_700"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/iv_language_arrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/gray_700" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- LANGUAGE EXPANDABLE CONTENT (Yangi dizayn) -->
            <LinearLayout
                android:id="@+id/layout_language_expandable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <RadioGroup
                    android:id="@+id/rg_languages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- O'zbekcha (Lotin) -->
                    <RadioButton
                        android:id="@+id/rb_uzbek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/selector_language_item_bg"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_radio_icon"
                        android:drawablePadding="12dp"
                        android:padding="16dp"
                        android:text="O'zbekcha (Lotin)"
                        android:textColor="@color/selector_text_color"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:checked="true"/>

                    <!-- O'zbekcha (Kirill) -->
                    <RadioButton
                        android:id="@+id/rb_uzbek_cyrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/selector_language_item_bg"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_radio_icon"
                        android:drawablePadding="12dp"
                        android:padding="16dp"
                        android:text="O'zbekcha (Kirill)"
                        android:textColor="@color/selector_text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Russian -->
                    <RadioButton
                        android:id="@+id/rb_russian"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/selector_language_item_bg"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_radio_icon"
                        android:drawablePadding="12dp"
                        android:padding="16dp"
                        android:text="Русский"
                        android:textColor="@color/selector_text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- English -->
                    <RadioButton
                        android:id="@+id/rb_english"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/selector_language_item_bg"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_radio_icon"
                        android:drawablePadding="12dp"
                        android:padding="16dp"
                        android:text="English"
                        android:textColor="@color/selector_text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Turkish -->
                    <RadioButton
                        android:id="@+id/rb_turkish"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/selector_language_item_bg"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_radio_icon"
                        android:drawablePadding="12dp"
                        android:padding="16dp"
                        android:text="Türkçe"
                        android:textColor="@color/selector_text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </RadioGroup>

                <!-- OK Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_language"
                    android:layout_width="120dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="OK"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="@color/primary"/>

            </LinearLayout>

            <!-- NOTIFICATIONS SECTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/layout_notifications_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Bildirishnomalar"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/gray_700" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>